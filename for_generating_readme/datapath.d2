# RV32I multi-cycle datapath — rendered with d2 (https://d2lang.com)
#   d2 --layout dagre --theme 200 --pad 40 datapath.d2 datapath.svg
direction: right

style.fill: "#070A12"

classes: {
  reg:  { style: { fill: "#101a2e"; stroke: "#60A5FA"; font-color: "#DCE6FF"; stroke-width: 2; border-radius: 10; shadow: true } }
  mem:  { style: { fill: "#2a1408"; stroke: "#F97316"; font-color: "#FFE3C7"; stroke-width: 2; border-radius: 10; shadow: true } }
  alu:  { style: { fill: "#13243d"; stroke: "#FACC15"; font-color: "#FDE68A"; stroke-width: 3; border-radius: 10; shadow: true } }
  imm:  { style: { fill: "#191634"; stroke: "#818CF8"; font-color: "#E2E0FF"; stroke-width: 2; border-radius: 10 } }
  cmp:  { style: { fill: "#1b1740"; stroke: "#A5B4FC"; font-color: "#E6E9FF"; stroke-width: 2; border-radius: 10 } }
  wb:   { style: { fill: "#0f2a1e"; stroke: "#6EE7B7"; font-color: "#CFFCE6"; stroke-width: 2; border-radius: 10; shadow: true } }
  ctrl: { style: { fill: "#2a0f1c"; stroke: "#F43F5E"; font-color: "#FFD9E0"; stroke-width: 3; border-radius: 12; shadow: true } }
}

CTRL: "Control FSM\n11 states" { class: ctrl }

PC: "PC\n32-bit" { class: reg }
MEM: "Unified Memory\ninstr + data" { class: mem }
IR: "Instruction\nRegister" { class: reg }
DEC: "Decode\nopcode · funct3 · funct7" { class: imm }
RF: "Register File\n32 × 32-bit" { class: reg }
IMM: "Immediate Gen\nI · S · B · U · J" { class: imm }
ALU: "ALU\nadd sub and or xor\nsll srl sra slt sltu" { class: alu }
CMP: "Branch Compare\nBEQ BNE BLT BGE BLTU BGEU" { class: cmp }
LSU: "Load / Store\nalign + mask" { class: mem }
EXEC: "exec_result\nwrite-back source" { class: wb }

PC -> MEM: mem_addr
MEM -> IR: mem_rdata
IR -> DEC
DEC -> RF: rs1 · rs2
DEC -> IMM
RF -> ALU: rs1_val
IMM -> ALU: "rs2_val / imm"
RF -> CMP
ALU -> LSU: mem_address
ALU -> EXEC: result
LSU -> EXEC: load data
LSU -> MEM: "mem_wdata · mem_wmask"
EXEC -> RF: "regfile[rd]"
CMP -> PC: branch target
EXEC -> PC: "next PC (+4 / imm)"

CTRL -> PC: {
  style.stroke-dash: 4
  style.stroke: "#F43F5E"
}
CTRL -> ALU: {
  style.stroke-dash: 4
  style.stroke: "#F43F5E"
}
CTRL -> LSU: {
  style.stroke-dash: 4
  style.stroke: "#F43F5E"
}
CTRL -> RF: {
  style.stroke-dash: 4
  style.stroke: "#F43F5E"
}
